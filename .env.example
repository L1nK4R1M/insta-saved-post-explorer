DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
ADMIN_PASSWORD_HASH=""
AUTH_DISABLED="false"
APP_OWNER_ID="local"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_LOGO_URL="/api/brand/logo"
IMPORT_MAX_BYTES="1000000"
# SHA-256 hash (64 hex chars) of the read-only external API key for /api/v1.
# Generate a key:  node -e "console.log('ipe_'+require('crypto').randomBytes(32).toString('base64url'))"
# Hash it:         node -e "console.log(require('crypto').createHash('sha256').update(process.argv[1]).digest('hex'))" "ipe_REPLACE_ME"
# Store only the hash here; never the raw key. Absent = /api/v1 fails closed (503).
EXTERNAL_API_KEY_SHA256=""
MEDIA_HOST_ALLOWLIST=""
MEDIA_PUBLIC_BASE_URL="https://pub-11ac111bad494fc2aa688c23c72d660a.r2.dev/"
MEDIA_PATH_PREFIX="originals"
R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
R2_BUCKET_NAME="insta-media"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Places (Phase F2) geographic resolver. Server-only — never prefix with
# NEXT_PUBLIC_ and never call Geoapify from the browser. Required only when the
# Places caption-resolution workflow runs; routes that do not use Places keep
# working without it. Empty = resolver construction fails closed with
# PLACES_RESOLVER_NOT_CONFIGURED.
GEOAPIFY_API_KEY=""
GEOAPIFY_API_BASE_URL="https://api.geoapify.com"
PLACES_RESOLVER_PROVIDER="geoapify"
PLACES_RESOLVER_TIMEOUT_MS="8000"
PLACES_RESOLVER_MAX_RESULTS="5"

# Worker-side only (VPS / GitHub Environments) — NOT required by the Vercel web app.
# Read-only R2 credential scoped to the media prefix on the same R2_BUCKET_NAME.
# Kept separate from the web upload credential above. See docs/deployment.md.
R2_WORKER_ACCESS_KEY_ID=""
R2_WORKER_SECRET_ACCESS_KEY=""
# Login DSN for the restricted PostgreSQL worker role (see docs/deployment.md).
# The role `ipe_worker_reader` is created NOLOGIN by migration; provision a login
# role that inherits it and set its password out-of-band, then put its DSN here.
WORKER_DATABASE_URL=""
