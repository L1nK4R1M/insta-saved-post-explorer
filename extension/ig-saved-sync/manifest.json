{
  "manifest_version": 3,
  "name": "Insta Saved Sync",
  "version": "4.1.0",
  "description": "Exportez vos posts Instagram sauvegardés et synchronisez les nouveaux médias avec Insta Post Explorer.",
  "action": {
    "default_title": "Insta Saved Sync",
    "default_icon": {
      "16": "icon/16.png",
      "32": "icon/32.png",
      "48": "icon/48.png",
      "128": "icon/128.png"
    }
  },
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "128": "icon/128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "cookies",
    "alarms",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*",
    "https://insta-saved-post-explorer.vercel.app/*",
    "http://localhost:3000/*",
    "https://insta-media.ea46bb39f3da0142d7eab15876a8a2a3.r2.cloudflarestorage.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://insta-saved-post-explorer.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    }
  ]
}
