generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  IMAGE
  CAROUSEL
  REEL
  OTHER
}

enum ImportStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum SyncStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Post {
  id              String           @id @default(cuid())
  ownerId         String           @default("local") @map("owner_id")
  externalId      String?          @map("external_id")
  postUrl         String           @map("post_url")
  thumbnailUrl    String           @map("thumbnail_url")
  mediaUrl        String?          @map("media_url")
  authorUsername  String           @map("author_username")
  authorSortKey   String           @map("author_sort_key")
  caption         String           @db.Text
  savedAt         DateTime?        @map("saved_at") @db.Timestamptz(3)
  publishedAt     DateTime?        @map("published_at") @db.Timestamptz(3)
  contentType     ContentType      @default(OTHER) @map("content_type")
  mainTheme       String?          @map("main_theme")
  likesCount      Int?             @map("likes_count")
  commentsCount   Int?             @map("comments_count")
  metadata        Json             @default("{}")
  searchText      String           @map("search_text") @db.Text
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  postTags        PostTag[]
  media           PostMedia[]
  collectionPosts CollectionPost[]

  @@unique([ownerId, postUrl], map: "posts_owner_id_post_url_key")
  @@index([ownerId, savedAt, id], map: "posts_owner_saved_at_id_idx")
  @@index([ownerId, publishedAt, id], map: "posts_owner_published_at_id_idx")
  @@index([ownerId, authorSortKey, id], map: "posts_owner_author_id_idx")
  @@index([ownerId, mainTheme], map: "posts_owner_main_theme_idx")
  @@index([ownerId, likesCount, id], map: "posts_owner_likes_count_id_idx")
  @@index([ownerId, commentsCount, id], map: "posts_owner_comments_count_id_idx")
  @@map("posts")
}

model Collection {
  id        String           @id @default(cuid())
  ownerId   String           @default("local") @map("owner_id")
  name      String
  slug      String
  isSystem  Boolean          @default(false) @map("is_system")
  isPublic  Boolean          @default(true) @map("is_public")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  posts     CollectionPost[]

  @@unique([ownerId, slug], map: "collections_owner_id_slug_key")
  @@index([ownerId, isPublic, name], map: "collections_owner_public_name_idx")
  @@map("collections")
}

model CollectionPost {
  collectionId String     @map("collection_id")
  postId       String     @map("post_id")
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  post         Post       @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([collectionId, postId])
  @@index([postId, collectionId], map: "collection_posts_post_id_collection_id_idx")
  @@map("collection_posts")
}

model PostMedia {
  id           String    @id @default(cuid())
  postId       String    @map("post_id")
  type         MediaType
  url          String?
  sourcePath   String?   @map("source_path")
  thumbnailUrl String?   @map("thumbnail_url")
  position     Int
  post         Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, position], map: "post_media_post_id_position_key")
  @@index([postId, position], map: "post_media_post_id_position_idx")
  @@map("post_media")
}

model Tag {
  id        String    @id @default(cuid())
  ownerId   String    @default("local") @map("owner_id")
  name      String
  slug      String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  postTags  PostTag[]

  @@unique([ownerId, slug], map: "tags_owner_id_slug_key")
  @@index([ownerId, name], map: "tags_owner_name_idx")
  @@map("tags")
}

model PostTag {
  postId    String   @map("post_id")
  tagId     String   @map("tag_id")
  isManual  Boolean  @default(false) @map("is_manual")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId, postId], map: "post_tags_tag_id_post_id_idx")
  @@map("post_tags")
}

model ImportJob {
  id             String       @id @default(cuid())
  ownerId        String       @default("local") @map("owner_id")
  idempotencyKey String       @default(cuid()) @map("idempotency_key")
  status         ImportStatus @default(RUNNING)
  sourceName     String?      @map("source_name")
  total          Int          @default(0)
  imported       Int          @default(0)
  updated        Int          @default(0)
  skipped        Int          @default(0)
  invalid        Int          @default(0)
  errorCode      String?      @map("error_code")
  startedAt      DateTime     @default(now()) @map("started_at") @db.Timestamptz(3)
  finishedAt     DateTime?    @map("finished_at") @db.Timestamptz(3)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@unique([ownerId, idempotencyKey], map: "import_jobs_owner_idempotency_key")
  @@index([ownerId, status, startedAt], map: "import_jobs_owner_status_started_idx")
  @@map("import_jobs")
}

model SyncJob {
  id            String     @id @default(cuid())
  ownerId       String     @default("local") @map("owner_id")
  status        SyncStatus @default(PENDING)
  collected     Int        @default(0)
  imported      Int        @default(0)
  updated       Int        @default(0)
  mediaUploaded Int        @default(0) @map("media_uploaded")
  mediaFailed   Int        @default(0) @map("media_failed")
  errorCode     String?    @map("error_code")
  startedAt     DateTime   @default(now()) @map("started_at") @db.Timestamptz(3)
  heartbeatAt   DateTime   @default(now()) @map("heartbeat_at") @db.Timestamptz(3)
  finishedAt    DateTime?  @map("finished_at") @db.Timestamptz(3)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([ownerId, startedAt], map: "sync_jobs_owner_started_idx")
  @@map("sync_jobs")
}
